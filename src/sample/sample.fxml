<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>

<GridPane alignment="center" hgap="10" vgap="10" xmlns="http://javafx.com/javafx/15.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sample.Controller">
   <columnConstraints>
      <ColumnConstraints />
   </columnConstraints>
   <rowConstraints>
      <RowConstraints />
   </rowConstraints>
   <children>
      <Pane prefHeight="151.0" prefWidth="505.0" style="-fx-background-color: #E0FFFF;">
         <effect>
            <Glow />
         </effect>
         <children>
            <TextField fx:id="textAreaInput" layoutX="51.0" layoutY="60.0" prefHeight="26.0" prefWidth="188.0" promptText="textArea1" style="-fx-background-color: #87CEEB; -fx-border-color: #4B0082;" />
            <TextField fx:id="textAreaOutput" layoutX="299.0" layoutY="61.0" prefHeight="26.0" prefWidth="188.0" promptText="textArea2" style="-fx-background-color: #87CEEB; -fx-border-color: #4B0082;" />
            <Button fx:id="buttonGeneratePassword" layoutX="172.0" layoutY="97.0" mnemonicParsing="false" prefHeight="32.0" prefWidth="162.0" text="Generate password" />
            <Label layoutX="14.0" layoutY="64.0" text="Input" />
            <Label layoutX="251.0" layoutY="65.0" text="Output" />
